# Copy to .env for local development.
# For a production store build, set VITE_CURATOR_API_URL to your deployed Curator app URL.

# Curator web app (API + connect-from-tab auth)
VITE_CURATOR_API_URL=http://127.0.0.1:3000

# Supabase — copy from the root app's .env.local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
